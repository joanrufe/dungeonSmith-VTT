# Dependencies
.venv/
python-embed-*/

# Python cache
__pycache__/
*.pyc
*.pyo

# Local secrets
secret.txt
data/private/**

# Local AI/tooling state
.claude/
.codex/

# Runtime scene data
data/scenes/**
!data/scenes/
!data/scenes/.gitkeep

# User-uploaded media and generated files
# /files (DM) writes to public/media/, /player-files writes to public/player-media/
public/uploads/**
!public/uploads/
!public/uploads/.gitkeep
public/music/**
!public/music/
!public/music/.gitkeep
public/media/**
!public/media/
!public/media/.gitkeep
public/player-media/**
!public/player-media/
!public/player-media/.gitkeep

# Runtime data files
data/sticky-notes.json
